{
  "name": "fujicard-monorepo",
  "version": "1.0.0",
  "description": "Fuji Card Market Monorepo for Vercel",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "sh -c 'cd client && npm install && npm run build && cd .. && rm -rf dist && mv client/dist dist'",
    "install:server": "cd server && npm install",
    "install:client": "cd client && npm install",
    "heroku-postbuild": "npm run build"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.1",
    "axios": "1.13.6",
    "bcryptjs": "^3.0.2",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.22.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "uuid": "^11.1.0"
  }
}
